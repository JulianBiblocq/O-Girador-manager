rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdminOrMestre() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          getUserData().role == 'mestre' || 
          getUserData().role == 'super-admin' || 
          getUserData().isSystemAdmin == true ||
          (getUserData().keys().hasAny(['hasAccessLogistique']) && getUserData().hasAccessLogistique == true)
        );
    }

    function isModerator() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          getUserData().role == 'mestre' || 
          getUserData().role == 'super-admin' || 
          getUserData().isSystemAdmin == true ||
          getUserData().role == 'moderator' ||
          (getUserData().keys().hasAny(['tags']) && 
           getUserData().tags.hasAny(['Modérateur', 'Modérateur Forum']))
        );
    }

    function hasChannelReadAccess(channelId) {
      return isAuthenticated() && (
        isAdminOrMestre() ||
        isModerator() ||
        (
          channelId != null &&
          exists(/databases/$(database)/documents/forum_channels/$(channelId)) &&
          getUserData().groupId == get(/databases/$(database)/documents/forum_channels/$(channelId)).data.groupId &&
          (
            get(/databases/$(database)/documents/forum_channels/$(channelId)).data.allowedRoles.hasAny([getUserData().role]) ||
            get(/databases/$(database)/documents/forum_channels/$(channelId)).data.allowedRoles.hasAny(['all']) ||
            get(/databases/$(database)/documents/forum_channels/$(channelId)).data.isTransparent == true
          )
        )
      );
    }

    function hasChannelWriteAccess(channelId) {
      return isAuthenticated() && (
        isAdminOrMestre() ||
        isModerator() ||
        (
          channelId != null &&
          exists(/databases/$(database)/documents/forum_channels/$(channelId)) &&
          getUserData().groupId == get(/databases/$(database)/documents/forum_channels/$(channelId)).data.groupId &&
          (
            get(/databases/$(database)/documents/forum_channels/$(channelId)).data.allowedRoles.hasAny([getUserData().role]) ||
            get(/databases/$(database)/documents/forum_channels/$(channelId)).data.allowedRoles.hasAny(['all'])
          )
        )
      );
    }

    // Collection Rules

    // Users: Read if authenticated. Write if editing own profile (without privilege escalation / status tampering) or if admin/mestre.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isAdminOrMestre() || (
          request.auth.uid == userId && (
            (!request.resource.data.keys().hasAny(['isSystemAdmin']) || request.resource.data.isSystemAdmin == false) &&
            (!request.resource.data.keys().hasAny(['paymentStatus']) || request.resource.data.paymentStatus == 'unpaid') &&
            (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == 'membre') &&
            (!request.resource.data.keys().hasAny(['statutActuel']) || request.resource.data.statutActuel == 'active') &&
            (!request.resource.data.keys().hasAny(['adhesionBase']) || request.resource.data.adhesionBase == true) &&
            (!request.resource.data.keys().hasAny(['selectedOptions']) || request.resource.data.selectedOptions.size() == 0) &&
            (!request.resource.data.keys().hasAny(['tags']) || request.resource.data.tags.size() == 0)
          )
        )
      );
      allow update: if isAuthenticated() && (
        isAdminOrMestre() || (
          request.auth.uid == userId && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'paymentStatus', 'role', 'isSystemAdmin', 'adhesionBase', 'selectedOptions', 'tags', 'statutActuel'
            ])
          )
        )
      );
      allow delete: if isAdminOrMestre();
    }

    // Inventory: Read if authenticated. Write (create, update, delete) reserved for admins/mestres.
    match /inventory/{item} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Associations: Read if authenticated. Write reserved for admins/mestres.
    match /associations/{assocId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();

      // Protected credentials only readable/writable by group administrators/mestres
      match /private_settings/credentials {
        allow read, write: if isAdminOrMestre() && getUserData().groupId == assocId;
      }
    }

    // Announcements: Read if authenticated. Write reserved for admins/mestres.
    match /announcements/{announcement} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Documents: Read if authenticated. Write reserved for admins/mestres.
    match /documents/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Wardrobe Inventory: Read if authenticated. Write reserved for admins/mestres.
    match /wardrobeInventory/{item} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Costumes & Pièces: Read if authenticated. Write reserved for admins/mestres.
    match /costumes/{costume} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Couture Projects: Read if authenticated. Write reserved for admins/mestres.
    match /coutureProjects/{project} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Rhythms: Read if authenticated. Write reserved for admins/mestres.
    match /rhythms/{rhythm} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Campaigns: Read if authenticated. Write reserved for admins/mestres.
    match /campaigns/{campaign} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrMestre();
    }

    // Events: Read if authenticated. Create/Delete for admins/mestres. Update allowed for RSVPs (members) or full update for admins/mestres.
    match /events/{event} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdminOrMestre();
      allow update: if isAuthenticated() && (
        isAdminOrMestre() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasAll(['inscriptions']) &&
         request.resource.data.diff(resource.data).affectedKeys().size() == 1)
      );
    }

    // Transactions: Read if authenticated. Write reserved for admins/mestres.
    match /transactions/{transaction} {
      allow read: if isAuthenticated() && (
        isAdminOrMestre() ||
        (resource == null || getUserData().groupId == resource.data.groupId)
      );
      allow write: if isAdminOrMestre() && (
        resource == null || getUserData().groupId == resource.data.groupId
      );
    }

    // Forum Channels: Read if member has roles/transparent, write only by admins (or create by group members)
    match /forum_channels/{channelId} {
      allow read: if isAuthenticated() && (
        isAdminOrMestre() ||
        (
          getUserData().groupId == resource.data.groupId &&
          (
            resource.data.allowedRoles.hasAny([getUserData().role]) ||
            resource.data.allowedRoles.hasAny(['all']) ||
            resource.data.isTransparent == true
          )
        )
      );
      allow create: if isAuthenticated() && request.resource.data.groupId == getUserData().groupId;
      allow update, delete: if isAdminOrMestre();
    }

    // Forum Threads: Read and Write allowed for members depending on channel permissions.
    match /forum/{thread} {
      allow read: if isAuthenticated() && (
        isAdminOrMestre() ||
        isModerator() ||
        hasChannelReadAccess(resource.data.channelId)
      );
      allow create: if isAuthenticated() && (
        hasChannelWriteAccess(request.resource.data.channelId)
      );
      allow update: if isAuthenticated() && (
        isModerator() ||
        (
          (hasChannelWriteAccess(resource.data.channelId) || !resource.data.keys().hasAny(['channelId'])) &&
          (!request.resource.data.keys().hasAny(['channelId']) || request.resource.data.channelId == resource.data.channelId)
        )
      );
      allow delete: if isAdminOrMestre() || isModerator();
    }

    // Campaign Requests: Read and Write allowed for all authenticated members.
    match /campaignRequests/{req} {
      allow read, write: if isAuthenticated();
    }

    // Private messages: Read and write restricted to sender or recipient
    match /private_messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.resource.data.senderId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        resource.data.recipientId == request.auth.uid &&
        (request.resource.data.diff(resource.data).affectedKeys().hasAll(['read']) &&
         request.resource.data.diff(resource.data).affectedKeys().size() == 1)
      );
      allow delete: if false;
    }

    // Pending payments: Only admins and mestres can access directly from client
    match /pending_payments/{email} {
      allow read, write: if isAdminOrMestre();
    }
  }
}
